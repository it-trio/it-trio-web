# Spotify API credentials for fetching episode links
# Get these from: https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here

# YouTube Data API v3 key for fetching video links
# Get this from: https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=your_youtube_api_key_here

# Amazon Music uses Puppeteer (browser automation) - no API key needed
# Install Puppeteer with: pnpm add -D puppeteer

# ElevenLabs API key for speech-to-text transcription (scribe_v2 model)
# Get this from: https://elevenlabs.io/ (Profile Settings > API Keys)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# OpenAI API key for Japanese text cleanup post-processing
# Get this from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here
